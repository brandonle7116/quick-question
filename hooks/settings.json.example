{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | { read -r f; [[ $f == *.cs ]] && ./scripts/unity-compile-smart.sh --timeout 15 || true; }",
            "timeout": 120,
            "statusMessage": "Compiling Unity..."
          },
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | { read -r f; [[ $f == */.claude/commands/*.md ]] && { echo \"$f\" >> /tmp/claude-skill-modified-marker; echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PostToolUse\",\"additionalContext\":\"[skill-modified] Skill file change recorded. Will check for /qq-self-review before ending.\"}}'; } || true; }"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/check-skill-review.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
